{
  "ConnectionStrings": {
    "DefaultConnection": "${MULKCHI_DB_CONNECTION_STRING}"
  },
  "JwtSettings": {
    "Secret": "${MULKCHI_JWT_SECRET}",
    "Issuer": "Mulkchi",
    "Audience": "MulkchiUsers",
    "ExpiryDays": 7
  },
  "EmailSettings": {
    "SmtpHost": "${MULKCHI_SMTP_HOST}",
    "SmtpPort": "${MULKCHI_SMTP_PORT}",
    "SenderEmail": "${MULKCHI_SENDER_EMAIL}",
    "SenderPassword": "${MULKCHI_SENDER_PASSWORD}",
    "SenderName": "Mulkchi"
  },
  "RateLimiting": {
    "Enabled": true
  },
  "AllowedOrigins": [
    "https://mulkchi.uz",
    "https://www.mulkchi.uz"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
